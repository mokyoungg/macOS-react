{
  // "files": [],
  // "references": [
  //   { "path": "./tsconfig.app.json" },
  //   { "path": "./tsconfig.node.json" }
  // ],
  "compilerOptions": {
    "composite": true, // 프로젝트 참조에 필요한 설정
    "noResolve": false, // 모듈을 찾을 때, `resolve`를 강제하지 않음

    /* 🛠️ 기본 설정 */
    "target": "ESNext", // 최신 JavaScript 문법 지원
    "module": "ESNext", // 최신 모듈 시스템 사용
    "moduleResolution": "bundler", // Node.js 방식으로 모듈 해석
    "rootDir": "./src", // 소스 코드 디렉토리
    "outDir": "./dist", // 컴파일된 파일 출력 경로
    "declaration": true, // `.d.ts` 타입 선언 파일 생성
    "sourceMap": true, // 디버깅을 위한 Source Map 생성
    "resolveJsonModule": true, // JSON 파일 import 가능하게 설정
    "allowJs": true, // `.js` 파일도 import 가능

    /* ⚡ 최적화 관련 */
    "incremental": true, // 증분 빌드 활성화 (컴파일 속도 향상)
    "tsBuildInfoFile": "./build.tsbuildinfo", // 증분 빌드 정보를 저장할 파일
    "isolatedModules": true, // 개별 모듈로 컴파일 (ESM 환경 최적화)

    /* 🔐 엄격한 타입 체크 */
    "strict": true, // 엄격한 타입 체크 활성화
    "noImplicitAny": true, // `any` 타입 명시적으로 선언하도록 강제
    "strictNullChecks": true, // `null`, `undefined` 타입 체크 강화
    "strictFunctionTypes": true, // 함수 타입 비교 강화
    "noImplicitThis": true, // `this` 타입 체크 강화
    "useUnknownInCatchVariables": true, // catch 문에서 `unknown` 타입 사용 강제

    /* 🚫 코드 품질 향상 */
    "noUnusedLocals": true, // 사용하지 않는 로컬 변수 경고
    "noUnusedParameters": true, // 사용하지 않는 함수 매개변수 경고
    "noFallthroughCasesInSwitch": true, // `switch` 문에서 break 누락 방지
    "noImplicitReturns": true, // 함수에서 모든 코드 경로가 값을 반환해야 함
    "noUncheckedIndexedAccess": true, // 인덱스 접근 시 타입 체크 강화

    /* 🎭 JSX 및 React 지원 */
    "jsx": "react-jsx", // React 17+의 자동 JSX 변환 사용
    "allowSyntheticDefaultImports": true, // 기본값이 없는 모듈도 `import` 가능
    "esModuleInterop": true, // CommonJS 모듈과 호환성 유지

    /* 📦 모듈 및 패키지 관련 */
    "skipLibCheck": true, // `.d.ts` 파일 검사를 생략하여 빌드 속도 향상
    "forceConsistentCasingInFileNames": true, // 파일 이름 대소문자 일관성 유지

    /* 절대경로 설정 */
    "baseUrl": "./src", // 경로 기준을 ./src 디렉토리로 설정
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"], // TypeScript가 컴파일할 파일이 있는 디렉토리
  "exclude": ["node_modules", "dist"] // 제외할 디렉토리
}
